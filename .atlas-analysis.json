  "keyFeatures": [
    "Firecracker microVM orchestration with REST API",
    "Subdomain-based reverse proxy with automatic routing",
    "Wake-on-request serverless pattern for idle VMs",
    "Snapshot/restore to S3-compatible storage",
    "Full networking stack with TAP, bridge, and DHCP",
    "SSH gateway with port forwarding and wake-on-SSH",
    "Automatic idle detection and snapshot"
  ],
  "publicApiSurface": [
    "POST /vms - Create and start a VM",
    "GET /vms - List all VMs",
    "GET /vms/{id} - Get VM details",
    "DELETE /vms/{id} - Delete VM",
    "POST /vms/{id}/stop - Stop running VM",
    "POST /vms/{id}/snapshot - Create snapshot",
    "POST /vms/{id}/restore - Restore from snapshot",
    "GET /vms/{id}/snapshots - List VM snapshots",
    "POST /vms/{id}/routes - Create proxy route",
    "GET /vms/{id}/routes - List VM routes",
    "DELETE /routes/{id} - Delete route",
    "GET /healthz - Health check"
  ]
}
